# Copy to .env (default) and optionally .env.local (local) or .env.production (production).
# Vite loads .env then .env.local in dev, and .env.production when building for production.

# Backend API origin (no trailing slash, no /api suffix).
# Local dev (recommended): leave empty and use the Vite proxy in vite.config.js — app on :5173, API on :8080.
# Alternative: set to http://localhost:8080 if the Express server runs there (do not run Vite on the same port).
VITE_API=
# Backend API base for product routes (optional; falls back to {VITE_API}/api or /api with proxy)
VITE_APP_API_URL=http://localhost:8080/api
VITE_FRONTEND_URL=http://localhost:5173
